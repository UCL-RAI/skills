{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/UCL-RAI/skills/catalog.schema.json",
  "title": "UCL-RAI Skills Catalog",
  "type": "object",
  "required": [
    "version",
    "name",
    "description",
    "homepage",
    "license",
    "compatibility",
    "maintainers",
    "contributors",
    "skills"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "compatibility": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contributors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "path",
        "type",
        "domain",
        "maturity",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "flow",
            "atomic",
            "reference",
            "tool"
          ]
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "maturity": {
          "enum": [
            "draft",
            "beta",
            "stable"
          ]
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_inspiration": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
